{
  "name": "@thebes/sdk",
  "version": "0.1.1",
  "description": "Thebes Protocol SDK \u2014 boundary client, typed React hooks, Memphis passkey auth, and (under ./motoko) the Motoko backend lib. Single source of truth shared by the Thebes example dapps.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Thebes Protocol contributors",
  "homepage": "https://github.com/Mercatura-Forum/thebes-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mercatura-Forum/thebes-sdk.git"
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./thebes": {
      "types": "./lib/thebes.d.ts",
      "import": "./lib/thebes.js"
    },
    "./boundary.js": "./runtime/boundary.js",
    "./passkey.js": "./runtime/passkey.js",
    "./runtime/*": "./runtime/*"
  },
  "files": [
    "dist",
    "runtime",
    "src",
    "README.md",
    "NOTICE"
  ],
  "scripts": {
    "oracle": "node oracle/encode-diff.mjs",
    "test": "node oracle/encode-diff.mjs"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
